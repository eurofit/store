    "generate:importmap": "payload generate:importmap",
    "generate:types": "payload generate:types",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check 'src/**/*.{js,ts,jsx,tsx,mjs,cjs,mts,cts,css}'",
    "format:fix": "prettier --write 'src/**/*.{js,ts,jsx,tsx,mjs,cjs,mts,cts,css}'",
    "payload": "payload",
    "payload:up": "pnpm up payload @payloadcms/* -L",
    "reinstall": "rimraf .next && rimraf pnpm-lock.yaml && pnpm install",
    "typecheck": "tsc --noEmit -p tsconfig.json --composite false",
    "start": "next start"
  },
